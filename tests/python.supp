# CPython's interpreter holds a number of long-lived allocations
# (interned strings, type objects, frozen modules) that are reported
# as "still reachable" by valgrind. Suppress them so the leak check
# focuses on Lean/LeanPy allocations.
{
   <python-frozen-modules>
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   fun:_Py_FreeList_Init
}
{
   <python-import-system>
   Memcheck:Leak
   match-leak-kinds: reachable
   ...
   obj:*libpython*
}
{
   <python-arena>
   Memcheck:Leak
   ...
   fun:PyObject_Malloc
}
# uv (Rust binary) triggers uninitialised-value warnings in its own
# thread pool.  These are harmless and not from our code.
{
   <uv-uninit-thread>
   Memcheck:Cond
   ...
   obj:*uv*
}
{
   <uv-uninit-thread-value>
   Memcheck:Value8
   ...
   obj:*uv*
}
# GMP allocations inside libleanshared (Lean's bignum layer).
{
   <lean-gmp-possible>
   Memcheck:Leak
   match-leak-kinds: possible
   fun:malloc
   ...
   fun:__gmp*
}
